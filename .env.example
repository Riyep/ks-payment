BOT_TOKEN=123456:telegram-bot-token
WEBHOOK_SECRET=ubah_dengan_secret_panjang
PUBLIC_BOT_URL=https://telegram-qris-payment-bot.username.workers.dev

# URL gambar yang bisa diakses publik. Bisa dari CDN, GitHub raw, atau image hosting.
LOGO_URL=https://example.com/logo-grup.png
QRIS_URL=https://example.com/qris-static.png

# ID grup/channel privat. Contoh: -1001234567890
GROUP_CHAT_ID=-1001234567890

# Optional: isi Telegram user ID admin, pisahkan dengan koma.
# Dipakai untuk approval manual saat QRIS static tidak punya webhook pembayaran.
ADMIN_IDS=123456789

# Optional: token rahasia untuk webhook payment gateway.
PAYMENT_WEBHOOK_SECRET=ubah_dengan_secret_payment_gateway
